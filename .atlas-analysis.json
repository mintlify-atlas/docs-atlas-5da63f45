  "keyFeatures": [
    "Anonymous ticket purchasing with QR code generation and email invoice delivery",
    "Marine species interactive database with habitat and conservation status tracking",
    "Visit reservation system with flexible date selection and PayPal/SINPE payment support",
    "Donations and volunteering portal for civic engagement",
    "Educational services and programs module for workshops and resources",
    "Admin dashboard with audit logs and institutional transparency reports",
    "JWT-based authentication with role-based access (public, client, admin)",
    "Supabase storage integration for media assets"
  ],
